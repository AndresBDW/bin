#!/bin/sh
# shlolcat: Versión POSIX pura (compatible con busybox sh, dash, etc.)

freq=0.2
slow=0

# Procesar parámetros estilo POSIX
while getopts "s" opt; do
    case "$opt" in
        s) slow=1 ;;
        *) exit 1 ;;
    esac
done
shift $(($OPTIND - 1))

line_idx=0
while IFS= read -r line; do
    line_idx=$((line_idx + 1))
    
    # Limpiamos códigos ANSI para que no interfieran con el arcoíris
    clean_line=$(printf '%s\n' "$line" | sed 's/\[[0-9;]*[a-zA-Z]//g')

    # Usamos awk para procesar la línea completa de una vez.
    # Esto es MUCHÍSIMO más rápido que usar 'cut' en un bucle while.
    printf '%s\n' "$clean_line" | awk -v f="$freq" -v y="$line_idx" -v s="$slow" '
    BEGIN {
        FS="" # Define cada carácter como un campo (funciona en la mayoría de awks)
    }
    {
        for (x=1; x<=NF; x++) {
            v = f * (x + y);
            r = int(sin(v) * 127 + 128);
            g = int(sin(v + 2) * 127 + 128);
            b = int(sin(v + 4) * 127 + 128);
            
            printf "\033[38;2;%d;%d;%dm%s\033[0m", r, g, b, $x;
            
            if (s == 1) {
                # Pequeño truco para el modo lento en awk
                system("sleep 0.005");
            }
        }
        printf "\n";
    }'
done

